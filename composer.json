{
    "name": "bachirdev-cmd/packages",
    "description": "Framework PHP modulaire pour applications de gestion citoyenne avec architecture DI et pattern Repository",
    "type": "library",
    "keywords": ["php", "framework", "dependency-injection", "repository-pattern", "modular", "mvc"],
    "homepage": "https://github.com/bachirdev-cmd/package_uchiwa",
    "license": "MIT",
    "authors": [
        {
            "name": "Pabass Diamé",
            "email": "pabassdiame76@gmail.com"
        }
    ],
    "require": {
        "cloudinary/cloudinary_php": "^3.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "AppDAF\\Repository\\": "src/repository/",
            "AppDAF\\Service\\": "src/service/",
            "AppDAF\\Controller\\": "src/controller/",
            "AppDAF\\Core\\": "app/core/",
            "AppDAF\\Abstracts\\": "app/core/abstract/",
            "AppDAF\\Enum\\": "src/enum/",
            "AppDAF\\Entity\\": "src/entity/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
